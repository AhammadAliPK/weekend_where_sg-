# WeekendWhere SG - Frontend Environment Variables
# Copy this file to .env and fill in your values
# Note: In Vite/SvelteKit, only variables prefixed with VITE_ are available to client code

# API Configuration
VITE_API_URL=http://localhost:3000

# Application Configuration
VITE_APP_NAME=WeekendWhere SG
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_WEATHER=true
VITE_ENABLE_MRT=true
VITE_ENABLE_DIRECTIONS=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_FAVORITES=true

# External API Keys (if needed on frontend)
# VITE_GOOGLE_MAPS_API_KEY=your-key-here
