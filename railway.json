{
  "build": {
    "command": "pnpm run build:api",
    "watch": [
      {
        "pattern": "apps/api/src/**",
        "command": "pnpm run build:api"
      },
      {
        "pattern": "packages/database/src/**",
        "command": "pnpm run build:api"
      }
    ]
  },
  "deploy": {
    "startCommand": "pnpm start",
    "healthcheckPath": "/api/health"
  }
}